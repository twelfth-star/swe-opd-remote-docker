# Copy this file to agent_rollout.env and edit the values.

# Python interpreter used for swe-opd helper scripts.
BOOTSTRAP_PYTHON_BIN="/mnt/data2/zhongmouhe/conda_envs/sweagent/bin/python"

# Python interpreter / environment where mini-swe-agent-plus dependencies exist.
MINI_PYTHON_BIN="/mnt/data2/zhongmouhe/conda_envs/sweagent/bin/python"

# Required: absolute path to the mini-swe-agent-plus repo on the rollout machine.
MINI_SWE_AGENT_PLUS_ROOT="/home/zhongmouhe/swe-re/mini-swe-agent-plus"

# Remote SGLang endpoint.
REMOTE_API_BASE="http://127.0.0.1:31000"
REMOTE_API_KEY="EMPTY"
REMOTE_MODEL_NAME="Kwai-Klear/Klear-AgentForge-8B"
REMOTE_PROVIDER="openai"
REMOTE_TEMPERATURE=0.0
REMOTE_DROP_PARAMS=true

# Optional: override the base agent config used to render the final config.
# Defaults to src/minisweagent/config/extra/swebench_add_edit_tool.yaml
# MINI_BASE_CONFIG="/path/to/custom/base_config.yaml"
MINI_BASE_CONFIG=/home/zhongmouhe/swe-re/mini-swe-agent-plus/src/minisweagent/config/extra/swebench.yaml


# Optional: extra model kwargs appended as JSON.
# REMOTE_EXTRA_MODEL_KWARGS_JSON={"top_p":1.0}

# Smoke-test prompt.
REMOTE_SMOKE_PROMPT="Reply with exactly: bootstrap-ok"

# SWE-bench defaults.
SWEBENCH_SUBSET="verified"
SWEBENCH_SPLIT="test"
SWEBENCH_WORKERS=2
SWEBENCH_DOCKER_START_CONCURRENCY=1

# Output roots inside this repo.
# SWEBENCH_OUTPUT_ROOT=

MSWEA_COST_TRACKING=ignore_errors # 绕过无法计费导致的报错
