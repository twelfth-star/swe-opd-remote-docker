# Copy this file to remote_rollout_client.env and edit the values on server A.

# Python interpreter used for swe-opd client helpers.
BOOTSTRAP_PYTHON_BIN="/projects/bdse/zhe3/uv_env/sglang/bin/python"

# Remote rollout service base URL. If using an SSH local forward, keep this as localhost.
REMOTE_ROLLOUT_SERVICE_BASE="http://127.0.0.1:18080"

# Optional bearer token for the rollout service.
REMOTE_ROLLOUT_API_TOKEN=

# When true, helper scripts create a local SSH tunnel from server A to server B.
REMOTE_ROLLOUT_USE_SSH_TUNNEL=true

# SSH details for server B.
REMOTE_ROLLOUT_SSH_USER="zhongmouhe"
REMOTE_ROLLOUT_SSH_HOST="taurus.cs.ucsb.edu"
REMOTE_ROLLOUT_SSH_KEY="/u/zhe3/.ssh/taurus_ssh_key"

# Local and remote port for the rollout service tunnel.
REMOTE_ROLLOUT_LOCAL_PORT="18080"
REMOTE_ROLLOUT_REMOTE_HOST="127.0.0.1"
REMOTE_ROLLOUT_REMOTE_PORT="18080"

# Optional reverse model tunnel cleanup settings.
# If you expose the model from server A to server B via `ssh -R`,
# fill the remote port here so the reset helper can kill that tunnel too.
REMOTE_MODEL_TUNNEL_REMOTE_PORT="32000"

# Optional output root on server A for saved result JSON files.
# REMOTE_ROLLOUT_OUTPUT_ROOT=

# Optional wait timeout in seconds. 0 means wait indefinitely.
REMOTE_ROLLOUT_WAIT_TIMEOUT=0
